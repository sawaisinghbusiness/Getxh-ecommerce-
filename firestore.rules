rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "XVQ4WNIRyKbJz7HCDUmU0Lv9squ2";
    }

    match /Users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      // list (collection query) needs isSignedIn() — userId filter in query ensures users only see their own
      allow list: if isSignedIn();
      allow get, update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /tickets/{ticketId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid;

      allow read: if isAdmin() ||
        (isSignedIn() &&
          exists(/databases/$(database)/documents/tickets/$(resource.data.ticketId)) &&
          get(/databases/$(database)/documents/tickets/$(resource.data.ticketId)).data.userId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /otp_codes/{docId} {
      allow read, write: if isSignedIn();
    }

    match /walletTxns/{txnId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
